# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
build/
dist/

# Local index artefacts and scratch
*.index.json
.brain/
scratch/
IMPLEMENTATION-PLAN.md

# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
