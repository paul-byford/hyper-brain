# Real tfvars hold environment-specific project ids and identities; commit only the
# .example templates. Copy an .example to <profile>.tfvars and fill it in.
config/*.tfvars
!config/*.tfvars.example

# Secrets and credentials (never commit)
*.key
*.pem
service-account*.json
application_default_credentials.json
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Downloaded local tooling (terraform, conftest, checkov binaries)
.tools/

# Generated Brain Explorer data (exported from the index)
ui/data/
