# Personal profile template. Copy this to personal.tfvars and fill in your values:
#   cp config/personal.tfvars.example config/personal.tfvars   (or copy on Windows)
#
# personal.tfvars is git-ignored, so your real project id and identities never get
# committed. `./brain up` reads personal.tfvars (and overrides project_id/region on
# the command line).

# Your Google Cloud project id, and who may invoke the services. Use a Google Group
# or a user (user:you@example.com) -- never allUsers (the config forbids it).
project_id      = "your-project-id"
invoker_members = ["group:your-admins@example.com"]

profile = "personal"
region  = "europe-west2"

# Disposable demo: buckets can be force-destroyed on teardown.
force_destroy_buckets = true

# Cloud-costly extras, off by default (near-zero idle cost). Flip observability on
# to export spans to your own Cloud Trace.
enable_observability      = false
enable_vpc_sc             = false
enable_workforce_identity = false

# --- OAuth for remote MCP connectors (Claude/ChatGPT "add by URL") ---
# The in-tenancy OAuth AS is provisioned by default. To actually enable remote
# connectors you must, after the first `./brain up` (which prints the auth URL),
# create a Google OAuth client (Web application) whose authorized redirect URI is
# <auth_url>/oauth2/callback, then paste its id/secret below and run `./brain up`
# again. Leaving these blank keeps the brain Google-identity-gated (no remote
# connectors, no public ingress). See the README "Remote connectors (OAuth)".
enable_oauth         = true
google_client_id     = ""
google_client_secret = ""

# Real policy grants, merged into the published policy at apply time (so your
# email is granted declaratively and never committed to the tracked config, which
# stays @example.com). Your identity is your bare Google email. Example:
# extra_grants = [
#   { principal = "you@example.com", domains = ["finserv-ai-engineering", "enterprise-ai-recruitment"], write = true },
# ]
extra_grants = []
