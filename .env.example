# hyper-brain environment variables (reference)
#
# These are OPTIONAL. The offline core runs with no environment set: every
# variable below has a sensible default. This file documents what exists and what
# it does. Copy it to `.env` if you like to keep your own values, but note the app
# reads real process environment variables, it does not auto-load a `.env` file
# yet, so set them in your shell (examples below) or let the cloud platform set
# them in production.
#
# Set for one command (Windows PowerShell):
#     $env:BRAIN_PROFILE = "personal"; python -m pytest app/tests -q
# Set for the session (Windows PowerShell):
#     $env:BRAIN_PROFILE = "personal"
# Set on macOS/Linux:
#     export BRAIN_PROFILE=personal

# Which audience profile to load. Selects config/<profile>.policy.yaml (and, in
# later phases, config/<profile>.tfvars). One of: personal | controlled.
BRAIN_PROFILE=personal

# Which embedding provider to use. "fake" is deterministic and offline (no cloud,
# no cost) and is the default. "vertex" uses first-party Vertex AI embeddings and
# needs the cloud settings below plus the [vertex] optional dependency installed.
# One of: fake | vertex.
BRAIN_EMBEDDINGS=fake

# --- Only needed when BRAIN_EMBEDDINGS=vertex (or other Vertex features) ---

# Your Google Cloud project id. No default: required for Vertex.
GOOGLE_CLOUD_PROJECT=

# Vertex region. Defaults to europe-west2 if unset.
GOOGLE_CLOUD_LOCATION=europe-west2

# --- Serving layer auth (phase 3, needs the [mcp] extra) ---

# How the MCP server verifies caller bearer tokens. "hs256" (default) verifies a
# shared-secret JWT with the standard library, for the offline core and the
# personal demo. "google" verifies production Google-signed OIDC ID tokens against
# Google's public keys (needs google-auth from the [mcp] extra).
# One of: hs256 | google.
BRAIN_AUTH=hs256

# Shared secret for BRAIN_AUTH=hs256. Required in that mode; there is no
# unauthenticated fallback. Generate one with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"
BRAIN_AUTH_SECRET=

# The token audience the server requires. For BRAIN_AUTH=google this MUST be the
# service URL (the Cloud Run URL). Optional but recommended for hs256.
BRAIN_AUTH_AUDIENCE=

# Expected token issuer, optional. For Google tokens: https://accounts.google.com
BRAIN_AUTH_ISSUER=

# Where the server loads the index artefact from on startup. A local path for the
# offline run, or a gs:// object in production.
BRAIN_INDEX=.brain/index.json
